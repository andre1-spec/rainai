+import React, { useState, useEffect } from 'react';
+import { Search, MapPin } from 'lucide-react';
+import { motion, AnimatePresence } from 'framer-motion';
+
+interface SearchBarProps {
+  onSelectAddress: () => void;
+  isHidden: boolean;
+}
+
+export const SearchBar: React.FC<SearchBarProps> = ({ onSelectAddress, isHidden }) => {
+  const [query, setQuery] = useState('');
+  const [showSuggestions, setShowSuggestions] = useState(false);
+
+  // Mock suggestion logic
+  useEffect(() => {
+    if (query.toLowerCase().startsWith('go') || query.toLowerCase().startsWith('gold')) {
+      setShowSuggestions(true);
+    } else {
+      setShowSuggestions(false);
+    }
+  }, [query]);
+
+  const handleSelect = () => {
+    setQuery('Goldschmidtstraße 100, Essen');
+    setShowSuggestions(false);
+    // Add a tiny delay to show the selected text before triggering the action
+    setTimeout(() => {
+      onSelectAddress();
+    }, 400);
+  };
+
+  return (
+    <motion.div 
+      className="absolute top-12 left-1/2 -translate-x-1/2 z-40 w-full max-w-2xl px-4"
+      initial={{ opacity: 0, y: -20 }}
+      animate={{ opacity: isHidden ? 0 : 1, y: isHidden ? -20 : 0, pointerEvents: isHidden ? 'none' : 'auto' }}
+      transition={{ duration: 0.5 }}
+    >
+      <div className="relative group">
+        {/* Glow effect */}
+        <div className="absolute -inset-0.5 bg-gradient-to-r from-pink-600 to-rose-600 rounded-2xl blur opacity-30 group-hover:opacity-60 transition duration-1000 group-hover:duration-200"></div>
+        
+        <div className="relative bg-[#121212]/90 backdrop-blur-md border border-gray-800 rounded-2xl shadow-2xl flex items-center p-3">
+          <Search className="text-gray-400 ml-2 w-6 h-6" />
+          <input
+            type="text"
+            className="w-full bg-transparent border-none outline-none text-white px-4 py-2 text-lg placeholder-gray-500 font-sans"
+            placeholder="Search building address..."
+            value={query}
+            onChange={(e) => setQuery(e.target.value)}
+            onFocus={() => {
+              if (query.toLowerCase().startsWith('go')) setShowSuggestions(true);
+            }}
+          />
+        </div>
+
+        {/* Suggestions Dropdown */}
+        <AnimatePresence>
+          {showSuggestions && (
+            <motion.div
+              initial={{ opacity: 0, y: 10 }}
+              animate={{ opacity: 1, y: 0 }}
+              exit={{ opacity: 0, y: 10 }}
+              className="absolute top-full mt-2 left-0 right-0 bg-[#121212]/95 backdrop-blur-xl border border-gray-800 rounded-xl overflow-hidden shadow-2xl"
+            >
+              <button
+                className="w-full text-left px-6 py-4 hover:bg-white/5 flex items-center space-x-3 transition-colors cursor-pointer"
+                onClick={handleSelect}
+              >
+                <div className="bg-pink-500/20 p-2 rounded-lg">
+                  <MapPin className="text-pink-500 w-5 h-5" />
+                </div>
+                <div>
+                  <p className="text-white font-medium">Goldschmidtstraße 100</p>
+                  <p className="text-gray-400 text-sm">Essen, Nordrhein-Westfalen, Germany</p>
+                </div>
+              </button>
+            </motion.div>
+          )}
+        </AnimatePresence>
+      </div>
+    </motion.div>
+  );
+};
